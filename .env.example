# Copy to .env and fill in real values. Never commit .env.

# ── Required ──────────────────────────────────────────────────────────
# Shared bearer token. Generate something high-entropy:
#   openssl rand -hex 32
CV_INVENTORY_API_KEY=

# Path inside the container to the catalog NPZ. Default matches the
# image's bake location and the single NPZ in catalogs/.
CV_INVENTORY_CATALOG_PATH=/app/catalogs/milo1-tcgplayer-mtg-2026-05.npz

# R2 credentials for syncing TCGplayer parquet metadata at boot.
R2_TCGPLAYER_BUCKET_ACCESS_KEY=
R2_TCGPLAYER_BUCKET_SECRET_KEY=
R2_TCGPLAYER_URL=https://<account-id>.r2.cloudflarestorage.com

# ── Optional ──────────────────────────────────────────────────────────
# TCGplayer category id. 1 = Magic. Change when supporting other games.
# CV_INVENTORY_TCGPLAYER_CATEGORY=1

# Confidence-tier thresholds (defaults calibrated against a 172-scan eval).
# CV_INVENTORY_CONF_GOOD_SCORE=0.55
# CV_INVENTORY_CONF_GOOD_GAP=0.15
# CV_INVENTORY_CONF_POOR_SCORE=0.45
# CV_INVENTORY_CONF_POOR_GAP=0.05
